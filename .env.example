# claude-mem credentials
# This file stores keys and gateway settings for the claude-mem memory agent.
# Copy this file to ~/.claude-mem/.env and fill in your values.
# See settings.json.example for the companion non-secret configuration.

# --- Anthropic SDK (provider=claude) ---
# Direct API key — used when CLAUDE_MEM_CLAUDE_AUTH_METHOD=api-key
ANTHROPIC_API_KEY=

# Gateway / proxy — used when CLAUDE_MEM_CLAUDE_AUTH_METHOD=gateway
# Example: DashScope Anthropic-compatible endpoint
ANTHROPIC_BASE_URL=
ANTHROPIC_AUTH_TOKEN=

# --- OpenRouter / DashScope (provider=openrouter) ---
# OpenRouter API key OR DashScope API key
# Also set in settings.json: CLAUDE_MEM_OPENROUTER_API_KEY
OPENROUTER_API_KEY=

# --- Gemini (provider=gemini) ---
# Google Gemini API key
# Also set in settings.json: CLAUDE_MEM_GEMINI_API_KEY
GEMINI_API_KEY=